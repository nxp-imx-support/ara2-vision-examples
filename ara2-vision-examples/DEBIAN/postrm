#!/bin/bash
# postrm script for ara2-vision-examples
# Copyright 2025-2026 NXP
# SPDX-License-Identifier: BSD-3-Clause

set -e

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[38;5;117m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'
# Unicode symbols
CHECK="[OK]"
CROSS="[X]"
ARROW="->"
WARNING="[!]"
# Package information
PACKAGE_NAME="ara2-vision-examples"
DEMO_EXEC="multistream_yolov8"
PACKAGE_VERSION="1.0.0"

# Helper functions for text formatting
_strip_ansi() {
  sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g'
}

_repeat_unit() {
  local __var="$1" __count="$2" __unit="$3"
  if (( __count <= 0 )); then
    printf -v "$__var" "%s" ""
    return
  fi
  local out=""
  local i
  for (( i=0; i<__count; i++ )); do
    out+="$__unit"
  done
  printf -v "$__var" "%s" "$out"
}

_repeat_char() {
  local __var="$1" __count="$2" __char="$3"
  if (( __count <= 0 )); then
    printf -v "$__var" "%s" ""
    return
  fi
  local spaces
  printf -v spaces "%*s" "$__count" ""
  local ch="${__char:0:1}"
  local val
  val=$(printf "%s" "$spaces" | LC_ALL=C tr ' ' "$ch")
  printf -v "$__var" "%s" "$val"
}

_center_visible() {
  local text="$1" width="$2" pad="${3:- }"
  local vis stripped total_pad left right L R
  stripped="$(printf "%s" "$text" | _strip_ansi)"
  vis="${#stripped}"
  
  (( vis < 0 )) && vis=0
  (( width < vis )) && width="$vis"
  
  total_pad=$(( width - vis ))
  (( total_pad < 0 )) && total_pad=0
  
  left=$(( total_pad / 2 ))
  right=$(( total_pad - left ))
  
  _repeat_char L "$left" "$pad"
  _repeat_char R "$right" "$pad"
  
  echo -e -n "$L" "${BOLD}${text}${RESET}" "$R"
}

header() {
  local title="$1"
  local min_width="80"
  local border_pad="═"
  
  if ! [[ "$min_width" =~ ^[0-9]+$ ]]; then
    printf "header: MIN_WIDTH must be an integer (got: %s)\n" "$min_width" >&2
    return 2
  fi
  
  local content
  content="${title}"
  
  local stripped visible inner_target outer_target
  stripped="$(printf "%s" "$content" | _strip_ansi)"
  visible="${#stripped}"
  
  outer_target=$(( visible + 2 + 2 ))
  if (( outer_target < min_width )); then
    outer_target="$min_width"
  fi
  
  local inner_width=$(( outer_target - 2 ))
  (( inner_width < 0 )) && inner_width=0
  
  local horiz
  _repeat_unit horiz "$inner_width" "$border_pad"
  
  printf "\n"
  echo -e "${BOLD}${CYAN}╔""$horiz""╗${RESET}"
  echo -e -n "${BOLD}${CYAN}║${RESET}  "
  
  local content_area=$(( inner_width - 4 ))
  (( content_area < 0 )) && content_area=0
  
  _center_visible "${content}" "$content_area" " "
  
  echo -e "${BOLD}${CYAN}║${RESET}"
  echo -e "${BOLD}${CYAN}╚""$horiz""╝${RESET}"
  printf "\n"
}

section() {
  echo -e "\n${BOLD}${BLUE}${ARROW} $1${RESET}"
  local sec
  _repeat_unit sec 80 "─"
  echo -e "${BLUE}${sec}${RESET}"
}

success() {
  echo -e "  ${GREEN}${CHECK}${RESET} $1"
}

error() {
  echo -e "  ${RED}${CROSS}${RESET} $1"
}

info() {
  echo -e "    $1"
}

warning() {
  echo -e "  ${YELLOW}${WARNING}${RESET}  $1"
}

remove_runtime_files() {
    local files_removed=0
    
    info "Removing runtime files and logs..."
    
    # Remove log files (with safe globbing)
    shopt -s nullglob
    
    for log_pattern in /var/log/ara2-vision* /var/log/multistream_yolov8*; do
        if [ -e "$log_pattern" ]; then
            rm -rf "$log_pattern" 2>/dev/null && ((files_removed++)) || true
        fi
    done
    
    # Remove temp files
    for tmp_pattern in /tmp/ara2-vision* /tmp/multistream_yolov8*; do
        if [ -e "$tmp_pattern" ]; then
            rm -rf "$tmp_pattern" 2>/dev/null && ((files_removed++)) || true
        fi
    done
    
    # Remove run files
    for run_pattern in /run/ara2-vision*; do
        if [ -e "$run_pattern" ]; then
            rm -rf "$run_pattern" 2>/dev/null && ((files_removed++)) || true
        fi
    done
    
    shopt -u nullglob
    
    if [ $files_removed -gt 0 ]; then
        success "Removed $files_removed runtime file(s) and log(s)"
    else
        info "No runtime files to remove"
    fi
    
    return 0
}

remove_shared_memory() {
    local shm_removed=0
    
    info "Cleaning shared memory segments..."
    
    # Remove shared memory files created by the application
    shopt -s nullglob
    
    for shm_pattern in /dev/shm/ara_stream_* /dev/shm/ara_inf_* /dev/shm/kinara_yolov8_*; do
        if [ -e "$shm_pattern" ]; then
            rm -f "$shm_pattern" 2>/dev/null && ((shm_removed++)) || true
        fi
    done
    
    shopt -u nullglob
    
    if [ $shm_removed -gt 0 ]; then
        success "Removed $shm_removed shared memory segment(s)"
    else
        info "No shared memory segments to remove"
    fi
    
    return 0
}

remove_user_data() {
    local data_removed=0
    
    info "Checking for user configuration data..."
    
    # Remove configuration directories
    for config_dir in /etc/ara2-vision /etc/multistream_yolov8; do
        if [ -d "$config_dir" ]; then
            if rm -rf "$config_dir" 2>/dev/null; then
                success "Removed configuration directory: $config_dir"
                ((data_removed++))
            else
                warning "Failed to remove configuration directory: $config_dir"
            fi
        fi
    done
    
    # Remove configuration files
    for config_file in /etc/ara2-vision.conf /etc/multistream_yolov8.conf; do
        if [ -f "$config_file" ]; then
            if rm -f "$config_file" 2>/dev/null; then
                success "Removed configuration file: $config_file"
                ((data_removed++))
            else
                warning "Failed to remove configuration file: $config_file"
            fi
        fi
    done
    
    if [ $data_removed -eq 0 ]; then
        info "No user data to remove"
    fi
    
    return 0
}

# Main script
case "$1" in
    remove)
        header "ARA-2 Vision Examples v$PACKAGE_VERSION - Remove"
        
        section "Cleaning System Cache"
        remove_runtime_files
        remove_shared_memory
        
        echo ""
        header "Cleanup completed successfully!"
        echo ""
        info "Package files have been removed"
        info "Sample videos at ${BOLD}/usr/share/ara2-vision-examples/sample_videos/${RESET} were preserved"
        info "Model files at ${BOLD}/usr/share/cnn/detection/yolov8n/${RESET} were preserved"
        info "To completely remove all data, use: ${BOLD}apt-get purge $PACKAGE_NAME${RESET}"
        echo ""
        ;;
        
    purge)
        header "ARA-2 Vision Examples v$PACKAGE_VERSION - Purge"
        
        section "Cleaning System Cache"
        remove_runtime_files
        remove_shared_memory
        
        section "Removing User Data"
        remove_user_data
        
        echo ""
        header "Purge completed successfully!"
        echo ""
        info "All package files and configurations have been removed"
        info "Sample videos at ${BOLD}/usr/share/ara2-vision-examples/sample_videos/${RESET} were preserved"
        info "Model files at ${BOLD}/usr/share/cnn/detection/yolov8n/${RESET} were preserved"
        echo ""
        ;;
        
    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        info "Package removal script called with: $1"
        # During upgrade, only clean temporary files, not configuration
        if [ "$1" = "upgrade" ]; then
            section "Cleaning Temporary Files (Upgrade)"
            remove_shared_memory
        fi
        ;;
        
    *)
        echo -e "${RED}${CROSS} postrm called with unknown argument '$1'${RESET}" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
